# Copy to .env and fill in (see README). Never commit .env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public games page: "json" (data/games.json) or "db" (Supabase games_catalog_v1 view).
GAMES_CATALOG_SOURCE=json
