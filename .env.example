# Copy to .env and fill in (see README). Never commit .env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public games page: "json" (data/games.json) or "db" (Supabase games_catalog_v1 view).
GAMES_CATALOG_SOURCE=db

# Optional: Kineticist MCP (.cursor/mcp.json). Cursor reads ${env:...} at startup; set this
# in Windows User environment variables (or your shell profile on macOS/Linux), then restart Cursor.
# Project .env is not loaded into Cursor automatically for MCP.
KINETICIST_API_KEY=
